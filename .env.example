# Distillery Configuration
# Copy to .env and fill in your values

DISTILLERY_DB=~/.openclaw/workspace/data/distillery/distillery.db
DISTILLERY_TTS_VOICE=en-US-AriaNeural
DISTILLERY_FFMPEG=ffmpeg
DISTILLERY_YT_TOKEN=/path/to/your/youtube-oauth-token.json
DISTILLERY_YT_CLIENT_SECRET=/path/to/your/youtube-client-secret.json
DISTILLERY_PROMPT=./prompts/summarize.md
DISTILLERY_TELEGRAM_CHAT=your_telegram_chat_id
DISTILLERY_YT_PLAYLIST=your_youtube_playlist_id
